{
    "private": true,
    "name": "campusdrive-monorepo",
    "version": "1.0.0",
    "scripts": {
        "dev:web": "cd Web && npm run dev",
        "format": "prettier --write .",
        "lint": "npm run lint --workspaces --if-present",
        "dev": "npm-run-all --parallel dev:web dev:be",
        "dev:mob": "cd Mob && npm run start",
        "dev:be": "cd BE && npm run dev"
    },
    "devDependencies": {
        "npm-run-all": "^4.1.5",
        "prettier": "^3.8.3"
    }
}
